{
  "manifest_version": 3,
  "name": "BetBCK Helper",
  "version": "0.1.0",
  "description": "Automate BetBCK search and show always-on-top EV popup with real-time updates.",
  "permissions": [
    "scripting",
    "tabs",
    "storage",
    "clipboardWrite",
    "clipboardRead",
    "debugger"
  ],
  "host_permissions": [
    "https://betbck.com/*",
    "https://plive.becoms.co/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://betbck.com/*", "https://plive.becoms.co/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["api_interceptor.js"],
      "matches": [
        "https://betbck.com/*",
        "http://betbck.com/*",
        "https://plive.becoms.co/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png"
  }
} 