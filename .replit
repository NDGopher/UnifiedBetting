modules = ["python-3.12", "web", "nodejs-20"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["cargo", "geckodriver", "glibcLocales", "libiconv", "libxcrypt", "rustc"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "cd frontend && npm install && npm run build && python -m uvicorn backend.main:app --host 0.0.0.0 --port 5000 --log-level info"]
build = ["bash", "-c", "cd frontend && npm install && npm run build"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
