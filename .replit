modules = ["python-3.12", "web", "nodejs-20"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["cargo", "geckodriver", "glibcLocales", "libiconv", "libxcrypt", "rustc"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "GitHub Auto-Sync"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && TZ=America/Chicago python -m uvicorn main:app --host 0.0.0.0 --port 8000 --log-level info"
waitForPort = 8000

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && PORT=5000 BROWSER=none HOST=0.0.0.0 WDS_SOCKET_PATH=/wds npm start"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "GitHub Auto-Sync"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python scripts/github_autosync.py --daemon"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "cd frontend && npm install && npm run build && python -m uvicorn backend.main:app --host 0.0.0.0 --port 5000 --log-level info"]
build = ["bash", "-c", "cd frontend && npm install && npm run build"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
