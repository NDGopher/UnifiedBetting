{
  "manifest_version": 3,
  "name": "Odds Dropper",
  "version": "1.3",
  "description": "Monitors POD for alerts.",
  "permissions": [
    "activeTab",
    "tabs",
    "webRequest",
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "https://www.pinnacleoddsdropper.com/*",
    "https://swordfish-production.up.railway.app/*",
    "http://localhost:8000/*",
    "http://localhost:5001/*",
    "http://127.0.0.1:8000/*",
    "https://*.replit.dev/*",
    "https://*.replit.dev:8000/*",
    "https://*.spock.replit.dev/*",
    "https://*.spock.replit.dev:8000/*"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.pinnacleoddsdropper.com/",
        "https://www.pinnacleoddsdropper.com/terminal",
        "https://www.pinnacleoddsdropper.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png"
    },
    "default_title": "Odds Dropper"
  }
}
